# QoLauncher — environment template
# Used by launcher.sh (global defaults) and docker compose.
#
# Per-app overrides: apps/<app-id>/.env  (APP_PORT, LOG_PORT, etc.)
# Quick start: cp .env.example .env && ./launcher.sh

# Application (set per service in generated compose; defaults below)
APP_BINARY=/app/server
APP_ARGS=
APP_PORT=8080
APP_WORKDIR=/app

# Process supervisor
APP_RESTART_POLICY=on-failure
APP_RESTART_DELAY=3s
APP_MAX_RESTART=0
APP_RESTART_WINDOW=60s
APP_RESTART_BURST=10
APP_SHUTDOWN_TIMEOUT=30s

# Logging
LOG_DIR=/var/log/qolauncher
LOG_RETENTION_DAYS=30
LOG_LEVEL=info
TZ=UTC

# Log viewer
LOG_PORT=8081
LOG_USERNAME=admin
LOG_PASSWORD=change-me-in-production
VIEWER_ENABLED=true

# Health check (optional — probes APP HTTP endpoint)
HEALTHCHECK_ENABLED=true
HEALTHCHECK_TYPE=http
HEALTHCHECK_URL=http://127.0.0.1:8080/health
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_FAILURES=3
